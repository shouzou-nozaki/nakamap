spring:
  application:
    name: backend
  datasource:
    url: ${DB_URL:jdbc:postgresql://localhost:5432/nakamap}
    username: ${DB_USER:nakamap}
    password: ${DB_PASSWORD:your_db_password_here}
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false
    properties:
      hibernate:
        format_sql: true
  flyway:
    enabled: true
    locations: classpath:db/migration

jwt:
  secret: ${JWT_SECRET:your_jwt_secret_here_must_be_at_least_32_characters}
  expiration: 86400000

server:
  port: 8080

logging:
  level:
    com.nakamap: DEBUG
